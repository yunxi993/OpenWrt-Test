#!/bin/sh

# Trigger only when the pppoe-wan interface comes completely up
if [ "$ACTION" = "ifup" ] && [ "$DEVICE" = "pppoe-wan" ]; then

    # Match the configurations from your main script
    rfc=4096
    threads=$(grep -c "processor" "/proc/cpuinfo")
    cpu_mask=$(printf '%x' $(( (1 << threads) - 1 )))

    # Wait 2 seconds to make sure the virtual directory tree finishes instantiating
    sleep 2

    # Target pppoe-wan directly now that it safely exists
    if [ -d "/sys/class/net/pppoe-wan/queues/rx-0" ]; then
        echo "$cpu_mask" > /sys/class/net/pppoe-wan/queues/rx-0/rps_cpus
        echo "$rfc" > /sys/class/net/pppoe-wan/queues/rx-0/rps_flow_cnt
    fi
fi
